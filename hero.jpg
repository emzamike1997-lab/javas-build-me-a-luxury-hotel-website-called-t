");
    background-size: cover;
    background-position: center;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
}

.hero h1 {
    font-size: 48px;
}

.hero p {
    font-size: 18px;
}

.rooms {
    padding: 2em;
}

.room-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-gap: 20px;
}

.room {
    background-color: #f7f7f7;
    padding: 1em;
    border: 1px solid #ddd;
}

.room img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 10px;
}

.room h3 {
    font-size: 18px;
    margin-top: 10px;
}

.room p {
    font-size: 14px;
    color: #666;
}

.amenities {
    padding: 2em;
}

.amenities ul {
    list-style: none;
    margin: 0;
    padding: 0;
}

.amenities li {
    margin-bottom: 10px;
}

.amenities li:before {
    content: "\2022";
    margin-right: 10px;
}

footer {
    background-color: #333;
    color: #fff;
    padding: 1em;
    text-align: center;
    clear: both;
}